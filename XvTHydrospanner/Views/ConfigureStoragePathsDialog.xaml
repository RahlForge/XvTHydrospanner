<Window x:Class="XvTHydrospanner.Views.ConfigureStoragePathsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Storage Locations" Height="450" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#252526">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Configure Storage Locations" FontSize="18" FontWeight="Bold"
                       Foreground="White" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#CCCCCC" LineHeight="20"
                       Text="XvT Hydrospanner needs locations to store mod and profile data. Default paths are pre-filled — accept them or choose your own."/>
        </StackPanel>

        <!-- Path entries (scrollable) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
            <StackPanel>

                <!-- Mod Warehouse -->
                <TextBlock Text="Mod Warehouse" FontWeight="SemiBold" Foreground="White"
                           Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="WarehousePathTextBox" Grid.Column="0"
                             Height="28" Padding="6,4" Margin="0,0,8,0"
                             Background="#1E1E1E" Foreground="White" CaretBrush="White"
                             BorderBrush="#3F3F46" BorderThickness="1"
                             VerticalContentAlignment="Center" FontSize="11"/>
                    <Button Grid.Column="1" Content="Browse..." Width="80" Height="28"
                            Click="BrowseWarehouse_Click"/>
                </Grid>

                <!-- Profiles -->
                <TextBlock Text="Profiles" FontWeight="SemiBold" Foreground="White"
                           Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ProfilesPathTextBox" Grid.Column="0"
                             Height="28" Padding="6,4" Margin="0,0,8,0"
                             Background="#1E1E1E" Foreground="White" CaretBrush="White"
                             BorderBrush="#3F3F46" BorderThickness="1"
                             VerticalContentAlignment="Center" FontSize="11"/>
                    <Button Grid.Column="1" Content="Browse..." Width="80" Height="28"
                            Click="BrowseProfiles_Click"/>
                </Grid>

                <!-- Mod Backups -->
                <TextBlock Text="Mod Backups" FontWeight="SemiBold" Foreground="White"
                           Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="BackupPathTextBox" Grid.Column="0"
                             Height="28" Padding="6,4" Margin="0,0,8,0"
                             Background="#1E1E1E" Foreground="White" CaretBrush="White"
                             BorderBrush="#3F3F46" BorderThickness="1"
                             VerticalContentAlignment="Center" FontSize="11"/>
                    <Button Grid.Column="1" Content="Browse..." Width="80" Height="28"
                            Click="BrowseBackup_Click"/>
                </Grid>

                <!-- Base Game Backup -->
                <TextBlock Text="Base Game Backup" FontWeight="SemiBold" Foreground="White"
                           Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="BaseGameBackupPathTextBox" Grid.Column="0"
                             Height="28" Padding="6,4" Margin="0,0,8,0"
                             Background="#1E1E1E" Foreground="White" CaretBrush="White"
                             BorderBrush="#3F3F46" BorderThickness="1"
                             VerticalContentAlignment="Center" FontSize="11"/>
                    <Button Grid.Column="1" Content="Browse..." Width="80" Height="28"
                            Click="BrowseBaseGameBackup_Click"/>
                </Grid>
                <TextBlock Text="This folder will store a full copy of your clean game installation."
                           FontSize="10" FontStyle="Italic" Foreground="#999999" Margin="0,4,0,0"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel (Exit App)" Width="130" Height="30"
                    Margin="0,0,10,0" Click="CancelButton_Click"/>
            <Button x:Name="OkButton" Content="Use These Paths" Width="130" Height="30"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True" Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

